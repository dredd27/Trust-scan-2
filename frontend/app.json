{
  "expo": {
    "name": "SOS Truffa",
    "slug": "sos-truffa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sostruffa",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "Hai ricevuto un messaggio sospetto? Verifica in pochi passaggi se è una truffa. Analisi AI integrata per screenshot e testo.",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dredd27.sostruffa",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Carica screenshot di messaggi sospetti",
        "CFBundleDisplayName": "SOS Truffa"
      }
    },
    "android": {
      "package": "com.dredd27.sostruffa",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["READ_MEDIA_IMAGES", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#F0F6FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
